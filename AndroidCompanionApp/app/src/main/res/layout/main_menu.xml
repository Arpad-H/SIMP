<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp"
    android:background="#121212"
    tools:context=".MainActivity">

    <!-- Titel -->
    <TextView
        android:id="@+id/textTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="12dp"
        android:letterSpacing="0.08"
        android:text="RIFTBORN"
        android:textColor="#FFFFFF"
        android:textSize="34sp"
        android:textStyle="bold" />

    <!-- Username -->
    <TextView
        android:id="@+id/textUsername"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Player: MaxMustermann"
        android:textSize="18sp"
        android:textColor="#BBBBBB"
        android:layout_marginBottom="48dp" />

    <!-- Play per Websocket -->
    <Button
        android:id="@+id/buttonWebsocket"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="20dp"
        android:text="🌐  Play per Websocket"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1E88E5"
        android:elevation="6dp" />

    <!-- Play per Bluetooth -->
    <Button
        android:id="@+id/buttonBluetooth"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="20dp"
        android:text="📶  Play per Bluetooth"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#00897B"
        android:elevation="6dp" />

    <!-- Change Name -->
    <Button
        android:id="@+id/buttonChangeName"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="20dp"
        android:text="✏️  Change Name"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#6A1B9A"
        android:elevation="6dp" />

    <!-- Card Collection -->
    <Button
        android:id="@+id/buttonCollection"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:text="🃏  Card Collection"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F4511E"
        android:elevation="6dp" />

</LinearLayout>